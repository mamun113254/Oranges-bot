{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip install -r requirements.txt && python -c \"import playwright; playwright.install()\""
  },
  "deploy": {
    "startCommand": "python bot.py",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "environment": {
    "PLAYWRIGHT_BROWSERS_PATH": "/cache/ms-playwright",
    "PYTHONUNBUFFERED": "1"
  }
}